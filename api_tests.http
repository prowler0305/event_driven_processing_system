Content-Type: application/json

{
  "event_id": "dup-test-123",
  "customer_name": "Andrew Spear",
  "address": "1234 Main Street, Chicago, IL",
  "items": [
    {"product_id": "P100",
      "quantity": 2
    }
  ]
}
