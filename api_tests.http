@host = http://localhost:5000

POST {{host}}/api/v1/orders
Content-Type: application/json

{
  "customer_name": "Andrew Spear",
  "address": "1234 Main Street, Chicago, IL",
  "items": [
    {"product_id": "P100",
      "quantity": 2
    }
  ]
}

### Duplicate event Test
